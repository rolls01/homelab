# ============================================================
# Homelab secrets — copy to .env and fill in values
# cp .env.example .env
# ============================================================
# This file is committed to git. Never commit .env itself.
# Each service only receives the variables it references
# in its compose file — no global env injection.
# ============================================================

# --- Pi-hole -------------------------------------------------
# Web UI / API password for Pi-hole v6+
# Rotate: change value here, then: docker compose restart pihole
PIHOLE_PASSWORD=

# --- Tailscale -----------------------------------------------
# Auth key from https://login.tailscale.com/admin/settings/keys
# Scope: one-time or reusable key for this device only
# Rotate: generate new key in Tailscale admin, update here,
#         then: docker compose up -d tailscale  (re-authenticates)
# Note: after first auth the key is no longer needed — state
#       persists in data/tailscale. Rotation only needed on re-auth.
TS_AUTHKEY=

# --- Telegram bot --------------------------------------------
# Bot token from @BotFather (https://t.me/BotFather → /newbot)
# Rotate: /revoke in BotFather, get new token, update here.
#         Scripts read this at runtime — no restart needed.
TELEGRAM_BOT_TOKEN=

# Chat ID — get via https://api.telegram.org/bot<TOKEN>/getUpdates
# after sending any message to the bot
TELEGRAM_CHAT_ID=

# --- Cloudflare ----------------------------------------------
# API token for DNS-01 challenge (Let's Encrypt wildcard certs)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Scope: Zone → DNS → Edit  (limit to specific zone only)
# Do NOT use Global API Key — scoped token is sufficient.
# Rotate: create new token in CF dashboard, delete old one,
#         update NPM DNS challenge config in the web UI.
CF_API_TOKEN=
